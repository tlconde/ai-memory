# Copy to .env.local (gitignored) and fill in real values.
# The harness parses this file directly via src/env.ts (no dotenv dep).

# Reader API key (Gemini). Required for `cli run`.
GEMINI_API_KEY=

# Judge API key (OpenAI). Required for `cli score` (invoked downstream by Python evaluate_qa.py).
OPENAI_API_KEY=

# Absolute path to the external SSD directory containing the LongMemEval datasets.
# Required for every run. No default — harness aborts if unset.
LME_DATA_DIR=/Volumes/SSD EXT/ai-memory-bench-data/longmemeval
