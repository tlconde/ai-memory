{
  "name": "ai-memory",
  "description": "Persistent project memory. Compound protocol, governance enforcement, MCP server. 4 skills, 2 agents.",
  "version": "0.1.0",
  "author": {
    "name": "radix-ai",
    "url": "https://github.com/radix-ai/ai-memory"
  },
  "mcpServers": {
    "ai-memory": {
      "type": "stdio",
      "command": "node",
      "args": [".ai/mcp-launcher.cjs"],
      "env": {
        "AI_DIR": "${workspaceFolder}/.ai"
      }
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "x-api-key": "${CONTEXT7_API_KEY:-}"
      }
    }
  }
}
