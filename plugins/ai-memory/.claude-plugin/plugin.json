{
  "name": "ai-memory",
  "version": "0.1.0",
  "description": "Persistent project memory with multi-agent collaboration. 5 skills, 2 agents, 2 rules, 12 MCP tools (search, commit, claim, sync, governance).",
  "author": {
    "name": "radix-ai",
    "url": "https://github.com/radix-ai/ai-memory"
  },
  "homepage": "https://github.com/radix-ai/ai-memory",
  "repository": "https://github.com/radix-ai/ai-memory",
  "license": "MIT",
  "keywords": ["ai", "memory", "compound", "mcp", "knowledge-management"],
  "mcpServers": {
    "ai-memory": {
      "type": "stdio",
      "command": "node",
      "args": [".ai/mcp-launcher.cjs"],
      "env": {
        "AI_DIR": "${workspaceFolder}/.ai"
      }
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "x-api-key": "${CONTEXT7_API_KEY:-}"
      }
    }
  }
}
