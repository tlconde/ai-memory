{
  "name": "ai-memory",
  "version": "0.1.0",
  "description": "Persistent project memory with multi-agent collaboration. 4 skills, 2 agents, 12 MCP tools (search, commit, claim, sync, governance).",
  "author": {
    "name": "radix-ai",
    "url": "https://github.com/radix-ai/ai-memory"
  },
  "homepage": "https://github.com/radix-ai/ai-memory",
  "repository": "https://github.com/radix-ai/ai-memory",
  "license": "MIT",
  "keywords": ["ai", "memory", "compound", "mcp", "knowledge-management"],
  "mcpServers": {
    "ai-memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["@radix-ai/ai-memory", "mcp"],
      "env": {
        "AI_DIR": "${workspaceFolder}/.ai"
      }
    }
  }
}
