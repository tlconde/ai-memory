{
  "mcpServers": {
    "ai-memory": {
      "type": "stdio",
      "command": "node",
      "args": [".ai/mcp-launcher.cjs"],
      "env": {
        "AI_DIR": "${workspaceFolder}/.ai"
      }
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "x-api-key": "${CONTEXT7_API_KEY:-}"
      }
    }
  }
}
